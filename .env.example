# ─── Supabase ─────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your project values.
# Find these in: Supabase dashboard → Project Settings → API
#
# IMPORTANT: VITE_* variables are bundled into the JS bundle and visible
# to anyone who inspects the browser source. Use only the anon/public key here.
# Never put the service_role key or any secret in VITE_* variables.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── AI Diagnosis (future) ────────────────────────────────────────────────────
# Claude API key must NEVER go in VITE_* vars — it would be exposed in the bundle.
# The diagnosis feature POSTs to a Supabase Edge Function that holds the key
# server-side. Set the endpoint URL here (not the key itself).
#
# VITE_DIAGNOSIS_ENDPOINT=https://your-project-ref.supabase.co/functions/v1/diagnose
